@prefix : <http://www.semanticweb.org/zteplez/video-game-rec-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/zteplez/video-game-rec-ontology#> .

<http://www.semanticweb.org/zteplez/video-game-rec-ontology> rdf:type owl:Ontology ;
                                                              owl:versionIRI <http://www.semanticweb.org/zteplez/video-game-rec-ontology/2.0> ;
                                                              rdfs:comment "A domain ontology for video game recommendations." ;
                                                              rdfs:label "Video Game Ontology" ;
                                                              owl:versionInfo "v2.0" .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#availableOn
:availableOn rdf:type owl:ObjectProperty ;
             rdfs:domain :Game ;
             rdfs:range :Platform .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#canUseWeapon
:canUseWeapon rdf:type owl:ObjectProperty ;
              rdfs:domain :Game ;
              rdfs:range :Weapon .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#hasEnemyCharacter
:hasEnemyCharacter rdf:type owl:ObjectProperty ;
                   rdfs:domain :Game ;
                   rdfs:range :EnemyCharacter .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#hasGenre
:hasGenre rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Game ;
          rdfs:range :Genre .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#hasPlayerCharacter
:hasPlayerCharacter rdf:type owl:ObjectProperty ;
                    rdfs:domain :Game ;
                    rdfs:range :PlayerCharacter .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#hasRating
:hasRating rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:float .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#hasReleaseYear
:hasReleaseYear rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Character
:Character rdf:type owl:Class .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#EnemyCharacter
:EnemyCharacter rdf:type owl:Class ;
                rdfs:subClassOf :Character .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Game
:Game rdf:type owl:Class ;
      rdfs:seeAlso <http://dbpedia.org/ontology/VideoGame> .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Genre
:Genre rdf:type owl:Class .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#MultiplayerGame
:MultiplayerGame rdf:type owl:Class ;
                 rdfs:subClassOf :Game .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Platform
:Platform rdf:type owl:Class .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#PlayerCharacter
:PlayerCharacter rdf:type owl:Class ;
                 rdfs:subClassOf :Character .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#SinglePlayerGame
:SinglePlayerGame rdf:type owl:Class ;
                  rdfs:subClassOf :Game .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Weapon
:Weapon rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Horror
:Horror rdf:type owl:NamedIndividual ,
                 :Genre .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#PC
:PC rdf:type owl:NamedIndividual ,
             :Platform .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Pistol
:Pistol rdf:type owl:NamedIndividual ,
                 :Weapon .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Resident_Evil
:Resident_Evil rdf:type owl:NamedIndividual ,
                        :Game ;
               :availableOn :PC ;
               :hasEnemyCharacter :Zombie ;
               :hasGenre :Horror .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Silent_Hill
:Silent_Hill rdf:type owl:NamedIndividual ,
                      :Game .


###  http://www.semanticweb.org/zteplez/video-game-rec-ontology#Zombie
:Zombie rdf:type owl:NamedIndividual ,
                 :EnemyCharacter .


